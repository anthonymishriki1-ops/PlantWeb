<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PlantOS - Plant Management System</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Pixelify+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- React and ReactDOM -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    
    <!-- Babel Standalone for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html, body, #root {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        
        @keyframes gentle-sway {
            0%, 100% { transform: rotate(-2deg); }
            50% { transform: rotate(2deg); }
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, createContext, useContext } = React;

        // ============ HOOKS ============
        function useScreenSize() {
            const [screenSize, setScreenSize] = useState(() => {
                const width = window.innerWidth;
                const height = window.innerHeight;
                return {
                    width,
                    height,
                    isSmall: width < 640,
                    isMedium: width >= 640 && width < 1024,
                    isLarge: width >= 1024,
                    isPortrait: height > width,
                    isLandscape: width > height
                };
            });

            useEffect(() => {
                const handleResize = () => {
                    const width = window.innerWidth;
                    const height = window.innerHeight;
                    setScreenSize({
                        width,
                        height,
                        isSmall: width < 640,
                        isMedium: width >= 640 && width < 1024,
                        isLarge: width >= 1024,
                        isPortrait: height > width,
                        isLandscape: width > height
                    });
                };

                window.addEventListener('resize', handleResize);
                window.addEventListener('orientationchange', handleResize);
                
                return () => {
                    window.removeEventListener('resize', handleResize);
                    window.removeEventListener('orientationchange', handleResize);
                };
            }, []);

            return screenSize;
        }

        // ============ CONTEXTS ============
        const NavigationContext = createContext(undefined);

        function NavigationProvider({ children }) {
            const [currentScreen, setCurrentScreen] = useState('splash');
            const [history, setHistory] = useState(['splash']);

            const navigate = (screen) => {
                setCurrentScreen(screen);
                setHistory(prev => [...prev, screen]);
            };

            const goBack = () => {
                if (history.length > 1) {
                    const newHistory = [...history];
                    newHistory.pop();
                    const previousScreen = newHistory[newHistory.length - 1];
                    setCurrentScreen(previousScreen);
                    setHistory(newHistory);
                }
            };

            return (
                <NavigationContext.Provider value={{ currentScreen, navigate, goBack, history }}>
                    {children}
                </NavigationContext.Provider>
            );
        }

        function useNavigation() {
            const context = useContext(NavigationContext);
            if (!context) {
                throw new Error('useNavigation must be used within NavigationProvider');
            }
            return context;
        }

        const PlantDataContext = createContext(undefined);

        function PlantDataProvider({ children }) {
            const [plants, setPlants] = useState([]);
            const [logEntries, setLogEntries] = useState([]);
            const locations = ['Greenhouse', 'Living Room', 'Bedroom', 'Kitchen', 'Balcony', 'Garden'];

            const generatePID = () => {
                const timestamp = Date.now().toString(36);
                const random = Math.random().toString(36).substring(2, 7);
                return `P-${timestamp}-${random}`.toUpperCase();
            };

            const addPlant = (plantData) => {
                const newPlant = {
                    ...plantData,
                    pid: generatePID(),
                    createdAt: new Date()
                };
                setPlants(prev => [...prev, newPlant]);
                return newPlant;
            };

            const addLogEntry = (entryData) => {
                const newEntry = {
                    ...entryData,
                    timestamp: new Date(),
                    user: 'User'
                };
                setLogEntries(prev => [newEntry, ...prev]);
            };

            const getPlantByPid = (pid) => {
                return plants.find(p => p.pid === pid);
            };

            const getPlantsByLocation = (location) => {
                return plants.filter(p => p.location === location);
            };

            return (
                <PlantDataContext.Provider value={{
                    plants,
                    logEntries,
                    locations,
                    addPlant,
                    addLogEntry,
                    getPlantByPid,
                    getPlantsByLocation
                }}>
                    {children}
                </PlantDataContext.Provider>
            );
        }

        function usePlantData() {
            const context = useContext(PlantDataContext);
            if (!context) {
                throw new Error('usePlantData must be used within PlantDataProvider');
            }
            return context;
        }

        // ============ UI COMPONENTS ============
        function PlantButton({ children, variant = 'primary', onClick, disabled = false, className = '', selected = false }) {
            const baseStyles = "px-4 py-3 rounded-lg border-4 transition-all duration-150 font-semibold relative overflow-hidden";
            
            const variantStyles = {
                primary: selected 
                    ? "bg-[#6B9C3D] border-[#5A8C2D] text-white shadow-lg scale-105"
                    : "bg-[#8BB55C] border-[#6B9C3D] text-[#2A4A1A] shadow hover:scale-105",
                secondary: selected
                    ? "bg-[#5A8C9D] border-[#4A7C8D] text-white shadow-lg scale-105"
                    : "bg-[#7BB5CC] border-[#5A8C9D] text-[#1A3A4A] shadow hover:scale-105",
                ghost: selected
                    ? "bg-[#E8D4A8] border-[#C8B488] text-[#4A3020] shadow-lg scale-105"
                    : "bg-transparent border-[#C8B488] text-[#4A3020] hover:bg-[#E8D4A8]"
            };
            
            const disabledStyles = "opacity-50 cursor-not-allowed hover:scale-100";
            
            return (
                <button
                    onClick={onClick}
                    disabled={disabled}
                    className={`${baseStyles} ${variantStyles[variant]} ${disabled ? disabledStyles : 'cursor-pointer'} ${className}`}
                    style={{ fontFamily: "'Pixelify Sans', cursive" }}
                >
                    {selected && (
                        <span className="absolute right-3 top-1/2 -translate-y-1/2 text-xl animate-pulse">▶</span>
                    )}
                    {children}
                </button>
            );
        }

        function PlantInput({ label, value, onChange, placeholder = '', disabled = false, error = '', type = 'text', required = false }) {
            const handleChange = (e) => {
                onChange(e.target.value);
            };
            
            const inputStyles = `w-full px-3 py-2 bg-white border-4 rounded-lg transition-all ${
                error ? 'border-[#E74C3C]' : 'border-[#8B4513] focus:border-[#6B9C3D]'
            } outline-none disabled:opacity-50 disabled:cursor-not-allowed`;
            
            return (
                <div className="mb-4">
                    <label 
                        className="block mb-2 text-[#4A3020]"
                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                    >
                        {label} {required && <span className="text-[#E74C3C]">*</span>}
                    </label>
                    {type === 'textarea' ? (
                        <textarea
                            value={value}
                            onChange={handleChange}
                            placeholder={placeholder}
                            disabled={disabled}
                            rows={4}
                            className={inputStyles}
                            style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', resize: 'vertical' }}
                        />
                    ) : (
                        <input
                            type="text"
                            value={value}
                            onChange={handleChange}
                            placeholder={placeholder}
                            disabled={disabled}
                            className={inputStyles}
                            style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px' }}
                        />
                    )}
                    {error && (
                        <p 
                            className="mt-1 text-[#E74C3C]"
                            style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}
                        >
                            {error}
                        </p>
                    )}
                </div>
            );
        }

        function PlantSelect({ label, value, onChange, options, disabled = false, error = '', required = false }) {
            const handleChange = (e) => {
                onChange(e.target.value);
            };
            
            return (
                <div className="mb-4">
                    <label 
                        className="block mb-2 text-[#4A3020]"
                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                    >
                        {label} {required && <span className="text-[#E74C3C]">*</span>}
                    </label>
                    <select
                        value={value}
                        onChange={handleChange}
                        disabled={disabled}
                        className={`w-full px-3 py-2 bg-white border-4 rounded-lg transition-all ${
                            error ? 'border-[#E74C3C]' : 'border-[#8B4513] focus:border-[#6B9C3D]'
                        } outline-none disabled:opacity-50 disabled:cursor-not-allowed`}
                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px' }}
                    >
                        {options.map(opt => (
                            <option key={opt.value} value={opt.value}>{opt.label}</option>
                        ))}
                    </select>
                    {error && (
                        <p 
                            className="mt-1 text-[#E74C3C]"
                            style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}
                        >
                            {error}
                        </p>
                    )}
                </div>
            );
        }

        function PlantCard({ children, title, className = '' }) {
            return (
                <div className={`bg-gradient-to-b from-[#F4E4C1] to-[#E8D4A8] rounded-xl border-8 border-[#6B4423] shadow-lg p-4 ${className}`}>
                    {title && (
                        <h3 
                            className="text-[#4A3020] mb-3 pb-2 border-b-4 border-[#C8B488]"
                            style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '14px' }}
                        >
                            {title}
                        </h3>
                    )}
                    <div className="relative z-10">
                        {children}
                    </div>
                </div>
            );
        }

        function StatusMessage({ type, message, onClose }) {
            const colors = {
                success: 'bg-[#6B9C3D] border-[#5A8C2D] text-white',
                error: 'bg-[#E74C3C] border-[#C0392B] text-white',
                info: 'bg-[#3498DB] border-[#2980B9] text-white',
                loading: 'bg-[#F39C12] border-[#E67E22] text-white'
            };
            
            const icons = {
                success: '✓',
                error: '✗',
                info: 'ℹ',
                loading: '⏳'
            };
            
            return (
                <div 
                    className={`${colors[type]} border-4 rounded-lg px-4 py-3 mb-4 flex items-center justify-between shadow-lg`}
                >
                    <div className="flex items-center gap-3">
                        <span className="text-2xl">{icons[type]}</span>
                        <span style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}>
                            {message}
                        </span>
                    </div>
                    {onClose && (
                        <button onClick={onClose} className="text-xl hover:scale-110 transition-transform">
                            ✕
                        </button>
                    )}
                </div>
            );
        }

        function TabBar({ tabs, activeTab, onTabChange }) {
            return (
                <div className="flex bg-[#8B4513] rounded-lg border-4 border-[#6B4423] overflow-hidden mb-4">
                    {tabs.map((tab, index) => (
                        <button
                            key={tab.id}
                            onClick={() => onTabChange(tab.id)}
                            className={`flex-1 px-3 py-3 transition-all border-r-4 last:border-r-0 border-[#6B4423] ${
                                activeTab === tab.id 
                                    ? 'bg-[#F4E4C1] text-[#4A3020]' 
                                    : 'bg-[#6B4423] text-[#C8B488] hover:bg-[#8B5533]'
                            }`}
                            style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px', fontWeight: '600' }}
                        >
                            <div className="flex flex-col items-center gap-1">
                                <span className="text-lg">{tab.icon}</span>
                                <span>{tab.label}</span>
                            </div>
                        </button>
                    ))}
                </div>
            );
        }

        // ============ SCREENS ============
        function SplashScreen() {
            const { navigate } = useNavigation();
            const { isSmall } = useScreenSize();

            const handleStart = () => {
                navigate('home');
            };

            return (
                <div className={`h-full flex flex-col items-center justify-center ${isSmall ? 'p-4' : 'p-8'}`}>
                    <div className={`text-center ${isSmall ? 'mb-8' : 'mb-12'}`}>
                        <div className={`inline-block bg-[#8B4513] ${isSmall ? 'px-8 py-4' : 'px-12 py-6'} rounded-2xl border-4 border-[#654321] shadow-2xl`}>
                            <div className="mb-4 text-6xl">🌿</div>
                            <h1 
                                className="text-[#6B9C3D] mb-2"
                                style={{ 
                                    fontFamily: "'Press Start 2P', cursive",
                                    fontSize: isSmall ? '28px' : '36px',
                                    lineHeight: '1.6',
                                    textShadow: '4px 4px 0px #2A1810, -1px -1px 0px #8BB55C'
                                }}
                            >
                                PlantOS
                            </h1>
                            <p 
                                className="text-[#F4E4C1]"
                                style={{ 
                                    fontFamily: "'Pixelify Sans', cursive",
                                    fontSize: isSmall ? '13px' : '16px',
                                    fontWeight: '500'
                                }}
                            >
                                Plant Management System
                            </p>
                        </div>
                    </div>

                    <PlantButton 
                        onClick={handleStart}
                        variant="primary"
                        className={isSmall ? 'px-10 py-4 text-base' : 'px-16 py-5 text-lg'}
                    >
                        <span className="flex items-center gap-3">
                            <span>START</span>
                            <span>▶</span>
                        </span>
                    </PlantButton>

                    <p 
                        className={`${isSmall ? 'mt-6' : 'mt-8'} text-[#2A1810] opacity-70 bg-[#F4E4C1]/60 px-3 py-1 rounded`}
                        style={{ 
                            fontFamily: "'Press Start 2P', cursive",
                            fontSize: '8px'
                        }}
                    >
                        v1.0.0
                    </p>
                </div>
            );
        }

        function HomeScreen() {
            const { navigate } = useNavigation();
            const { plants } = usePlantData();
            const [selectedIndex, setSelectedIndex] = useState(0);
            const { isSmall } = useScreenSize();

            const menuOptions = [
                { id: 'add', label: 'Add Plant', icon: '🌱', screen: 'add-plant' },
                { id: 'locations', label: 'Locations', icon: '📍', screen: 'locations' },
                { id: 'log', label: 'Plant Log', icon: '📋', screen: 'plant-log' },
                { id: 'scan', label: 'Scan Plant', icon: '🔍', screen: 'plant-scan' },
                { id: 'spec', label: 'View Spec', icon: '📖', screen: 'spec' }
            ];

            const handleSelect = (index) => {
                setSelectedIndex(index);
                navigate(menuOptions[index].screen);
            };

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} max-w-2xl mx-auto w-full`}>
                    <PlantCard className="mb-4">
                        <div className="text-center">
                            <h2 
                                className="text-[#4A3020] mb-2"
                                style={{ fontFamily: "'Press Start 2P', cursive", fontSize: isSmall ? '14px' : '16px' }}
                            >
                                Welcome to PlantOS
                            </h2>
                            <div 
                                className={`text-[#6B4423] flex items-center justify-center ${isSmall ? 'gap-2' : 'gap-4'}`}
                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: isSmall ? '12px' : '14px', fontWeight: '600' }}
                            >
                                <div className="flex items-center gap-2">
                                    <span className={isSmall ? 'text-xl' : 'text-2xl'}>🌿</span>
                                    <span>{plants.length} Plants</span>
                                </div>
                                <div className="flex items-center gap-2">
                                    <span className={isSmall ? 'text-xl' : 'text-2xl'}>💚</span>
                                    <span>All Healthy</span>
                                </div>
                            </div>
                        </div>
                    </PlantCard>

                    <PlantCard title="MAIN MENU" className="flex-1">
                        <div className="space-y-3">
                            {menuOptions.map((option, index) => (
                                <PlantButton
                                    key={option.id}
                                    onClick={() => handleSelect(index)}
                                    selected={selectedIndex === index}
                                    variant="primary"
                                >
                                    <div className="flex items-center gap-3">
                                        <span className="text-2xl">{option.icon}</span>
                                        <span>{option.label}</span>
                                    </div>
                                </PlantButton>
                            ))}
                        </div>
                    </PlantCard>
                </div>
            );
        }

        function AddPlantScreen() {
            const { navigate, goBack } = useNavigation();
            const { addPlant, locations } = usePlantData();
            const { isSmall } = useScreenSize();
            
            const [name, setName] = useState('');
            const [location, setLocation] = useState(locations[0]);
            const [formState, setFormState] = useState('default');
            const [createdPID, setCreatedPID] = useState('');
            const [errors, setErrors] = useState({ name: '', location: '' });

            const validateForm = () => {
                const newErrors = { name: '', location: '' };
                let isValid = true;

                if (!name.trim()) {
                    newErrors.name = 'Display name is required';
                    isValid = false;
                }

                if (!location) {
                    newErrors.location = 'Location is required';
                    isValid = false;
                }

                setErrors(newErrors);
                return isValid;
            };

            const handleSubmit = () => {
                if (!validateForm()) {
                    setFormState('error');
                    return;
                }

                setFormState('loading');

                setTimeout(() => {
                    try {
                        const newPlant = addPlant({ name, location });
                        setCreatedPID(newPlant.pid);
                        setFormState('success');
                    } catch (error) {
                        setFormState('error');
                    }
                }, 1000);
            };

            const handleReset = () => {
                setName('');
                setLocation(locations[0]);
                setFormState('default');
                setCreatedPID('');
                setErrors({ name: '', location: '' });
            };

            const handleOpenScan = () => {
                navigate('plant-scan');
            };

            const locationOptions = locations.map(loc => ({ value: loc, label: loc }));

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} overflow-y-auto max-w-2xl mx-auto w-full`}>
                    <PlantCard title="ADD NEW PLANT">
                        {formState === 'loading' && (
                            <StatusMessage type="loading" message="Creating specimen..." />
                        )}

                        {formState === 'error' && (
                            <StatusMessage 
                                type="error" 
                                message="Please fix the errors below" 
                                onClose={() => setFormState('default')}
                            />
                        )}

                        {formState === 'success' && (
                            <>
                                <StatusMessage 
                                    type="success" 
                                    message={`Plant created successfully!`}
                                />
                                <div className="mb-4 p-4 bg-white rounded-lg border-4 border-[#6B9C3D]">
                                    <p 
                                        className="text-[#4A3020] mb-2"
                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                                    >
                                        Generated Plant ID:
                                    </p>
                                    <p 
                                        className="text-[#6B9C3D] mb-4"
                                        style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '16px' }}
                                    >
                                        {createdPID}
                                    </p>
                                    <div className="space-y-2">
                                        <PlantButton onClick={handleOpenScan} variant="primary">
                                            Open Scan
                                        </PlantButton>
                                        <PlantButton onClick={handleReset} variant="secondary">
                                            Add Another Plant
                                        </PlantButton>
                                    </div>
                                </div>
                            </>
                        )}

                        {formState !== 'success' && (
                            <>
                                <PlantInput
                                    label="Display Name"
                                    value={name}
                                    onChange={setName}
                                    placeholder="e.g., Sunny the Succulent"
                                    error={errors.name}
                                    required
                                    disabled={formState === 'loading'}
                                />

                                <PlantSelect
                                    label="Location"
                                    value={location}
                                    onChange={setLocation}
                                    options={locationOptions}
                                    error={errors.location}
                                    required
                                    disabled={formState === 'loading'}
                                />

                                <div className="space-y-2 mt-6">
                                    <PlantButton 
                                        onClick={handleSubmit}
                                        variant="primary"
                                        disabled={formState === 'loading'}
                                    >
                                        {formState === 'loading' ? 'Creating...' : 'Create Specimen'}
                                    </PlantButton>
                                    <PlantButton onClick={goBack} variant="ghost">
                                        Cancel
                                    </PlantButton>
                                </div>
                            </>
                        )}
                    </PlantCard>
                </div>
            );
        }

        function LocationsScreen() {
            const { goBack, navigate } = useNavigation();
            const { locations, getPlantsByLocation } = usePlantData();
            const { isSmall } = useScreenSize();
            
            const [selectedLocation, setSelectedLocation] = useState(locations[0]);
            const [loadState, setLoadState] = useState('default');
            const [plants, setPlants] = useState(getPlantsByLocation(locations[0]));

            const handleRefresh = () => {
                setLoadState('loading');
                
                setTimeout(() => {
                    const locationPlants = getPlantsByLocation(selectedLocation);
                    setPlants(locationPlants);
                    setLoadState('default');
                }, 800);
            };

            const handleLocationChange = (location) => {
                setSelectedLocation(location);
                setPlants(getPlantsByLocation(location));
            };

            const locationOptions = locations.map(loc => ({ value: loc, label: loc }));

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} overflow-y-auto max-w-2xl mx-auto w-full`}>
                    <PlantCard title="LOCATIONS">
                        {loadState === 'loading' && (
                            <StatusMessage type="loading" message="Refreshing location data..." />
                        )}

                        {loadState === 'error' && (
                            <StatusMessage 
                                type="error" 
                                message="Failed to load plants" 
                                onClose={() => setLoadState('default')}
                            />
                        )}

                        <PlantSelect
                            label="Select Location"
                            value={selectedLocation}
                            onChange={handleLocationChange}
                            options={locationOptions}
                        />

                        <div className="flex gap-2 mb-4">
                            <PlantButton 
                                onClick={handleRefresh}
                                variant="secondary"
                                disabled={loadState === 'loading'}
                                className="flex-1"
                            >
                                <span className="text-xl mr-2">🔄</span>
                                {loadState === 'loading' ? 'Refreshing...' : 'Refresh'}
                            </PlantButton>
                        </div>

                        <div className="mb-4">
                            <h3 
                                className="text-[#4A3020] mb-3"
                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                            >
                                Plants in {selectedLocation}: {plants.length}
                            </h3>

                            {plants.length === 0 ? (
                                <div className="text-center py-8">
                                    <div className="text-6xl mb-4">🪴</div>
                                    <p 
                                        className="text-[#6B4423] mb-4"
                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px' }}
                                    >
                                        No plants in this location yet
                                    </p>
                                    <PlantButton 
                                        onClick={() => navigate('add-plant')}
                                        variant="primary"
                                    >
                                        Add First Plant
                                    </PlantButton>
                                </div>
                            ) : (
                                <div className="space-y-2 max-h-64 overflow-y-auto">
                                    {plants.map((plant) => (
                                        <div
                                            key={plant.pid}
                                            className="bg-white p-3 rounded-lg border-4 border-[#8B4513] cursor-pointer hover:border-[#6B9C3D] transition-all"
                                            onClick={() => navigate('plant-scan')}
                                        >
                                            <div className="flex items-center justify-between">
                                                <div>
                                                    <p 
                                                        className="text-[#4A3020]"
                                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                                                    >
                                                        {plant.name}
                                                    </p>
                                                    <p 
                                                        className="text-[#6B4423]"
                                                        style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '10px' }}
                                                    >
                                                        {plant.pid}
                                                    </p>
                                                </div>
                                                <span className="text-2xl">🌿</span>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>

                        <PlantButton onClick={goBack} variant="ghost">
                            Back to Home
                        </PlantButton>
                    </PlantCard>
                </div>
            );
        }

        function PlantLogScreen() {
            const { goBack } = useNavigation();
            const { logEntries } = usePlantData();
            const { isSmall } = useScreenSize();
            
            const [limit, setLimit] = useState('10');
            const [loadState, setLoadState] = useState('default');
            const [displayedEntries, setDisplayedEntries] = useState(logEntries.slice(0, 10));

            const limitOptions = [
                { value: '1', label: '1' },
                { value: '5', label: '5' },
                { value: '10', label: '10' },
                { value: '25', label: '25' },
                { value: '50', label: '50' }
            ];

            const handleLoad = () => {
                setLoadState('loading');
                
                setTimeout(() => {
                    const limitNum = parseInt(limit);
                    setDisplayedEntries(logEntries.slice(0, limitNum));
                    setLoadState('default');
                }, 600);
            };

            const formatDate = (date) => {
                return date.toLocaleString('en-US', { 
                    month: 'short', 
                    day: 'numeric', 
                    hour: '2-digit', 
                    minute: '2-digit' 
                });
            };

            const getActionColor = (action) => {
                const colors = {
                    WATER: 'text-[#3498DB]',
                    FERTILIZE: 'text-[#F39C12]',
                    REPOT: 'text-[#8B4513]',
                    NOTE: 'text-[#9B59B6]'
                };
                return colors[action] || 'text-[#4A3020]';
            };

            const getActionIcon = (action) => {
                const icons = {
                    WATER: '💧',
                    FERTILIZE: '🌾',
                    REPOT: '🪴',
                    NOTE: '📝'
                };
                return icons[action] || '📋';
            };

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} overflow-y-auto max-w-2xl mx-auto w-full`}>
                    <PlantCard title="PLANT LOG">
                        {loadState === 'loading' && (
                            <StatusMessage type="loading" message="Loading log entries..." />
                        )}

                        {loadState === 'error' && (
                            <StatusMessage 
                                type="error" 
                                message="Failed to load log entries" 
                                onClose={() => setLoadState('default')}
                            />
                        )}

                        <div className="flex gap-2 mb-4">
                            <div className="flex-1">
                                <PlantSelect
                                    label="Limit"
                                    value={limit}
                                    onChange={setLimit}
                                    options={limitOptions}
                                />
                            </div>
                            <div className="flex items-end">
                                <PlantButton 
                                    onClick={handleLoad}
                                    variant="primary"
                                    disabled={loadState === 'loading'}
                                >
                                    {loadState === 'loading' ? 'Loading...' : 'Load'}
                                </PlantButton>
                            </div>
                        </div>

                        <div className="mb-4">
                            <h3 
                                className="text-[#4A3020] mb-3"
                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                            >
                                Recent Entries: {displayedEntries.length}
                            </h3>

                            {displayedEntries.length === 0 ? (
                                <div className="text-center py-8">
                                    <div className="text-6xl mb-4">📋</div>
                                    <p 
                                        className="text-[#6B4423]"
                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px' }}
                                    >
                                        No log entries yet. Start caring for your plants!
                                    </p>
                                </div>
                            ) : (
                                <div className="space-y-2 max-h-96 overflow-y-auto">
                                    {displayedEntries.map((entry, index) => (
                                        <div
                                            key={index}
                                            className="bg-white p-3 rounded-lg border-4 border-[#8B4513]"
                                        >
                                            <div className="flex items-start justify-between mb-2">
                                                <div className="flex items-center gap-2">
                                                    <span className="text-2xl">{getActionIcon(entry.action)}</span>
                                                    <span 
                                                        className={`${getActionColor(entry.action)} font-bold`}
                                                        style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '10px' }}
                                                    >
                                                        {entry.action}
                                                    </span>
                                                </div>
                                                <span 
                                                    className="text-[#6B4423]"
                                                    style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '10px' }}
                                                >
                                                    {formatDate(entry.timestamp)}
                                                </span>
                                            </div>
                                            <p 
                                                className="text-[#4A3020] mb-1"
                                                style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '10px' }}
                                            >
                                                {entry.pid}
                                            </p>
                                            {entry.details && (
                                                <p 
                                                    className="text-[#6B4423]"
                                                    style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}
                                                >
                                                    {entry.details}
                                                </p>
                                            )}
                                            <p 
                                                className="text-[#8B4513] mt-2"
                                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '10px' }}
                                            >
                                                by {entry.user}
                                            </p>
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>

                        <PlantButton onClick={goBack} variant="ghost">
                            Back to Home
                        </PlantButton>
                    </PlantCard>
                </div>
            );
        }

        function PlantScanScreen() {
            const { goBack } = useNavigation();
            const { getPlantByPid, addLogEntry } = usePlantData();
            const { isSmall } = useScreenSize();
            
            const [plantId, setPlantId] = useState('');
            const [currentPlant, setCurrentPlant] = useState(null);
            const [activeTab, setActiveTab] = useState('status');
            const [submitState, setSubmitState] = useState('default');
            const [pidError, setPidError] = useState('');

            const [selectedAction, setSelectedAction] = useState('WATER');
            const [actionDetails, setActionDetails] = useState('');
            const [potSize, setPotSize] = useState('');
            const [substrate, setSubstrate] = useState('');
            const [note, setNote] = useState('');

            const tabs = [
                { id: 'status', label: 'Status', icon: '📊' },
                { id: 'action', label: 'Action', icon: '⚡' },
                { id: 'repot', label: 'Repot', icon: '🪴' },
                { id: 'note', label: 'Note', icon: '📝' }
            ];

            const actionOptions = [
                { value: 'WATER', label: '💧 Water' },
                { value: 'FERTILIZE', label: '🌾 Fertilize' },
                { value: 'REPOT', label: '🪴 Repot' },
                { value: 'NOTE', label: '📝 Note' }
            ];

            const handleScanPlant = () => {
                setPidError('');
                
                if (!plantId.trim()) {
                    setPidError('Plant ID is required');
                    return;
                }

                const plant = getPlantByPid(plantId.trim());
                
                if (!plant) {
                    setPidError('Plant not found');
                    setCurrentPlant(null);
                    return;
                }

                setCurrentPlant(plant);
                setActiveTab('status');
            };

            const handleSubmitAction = () => {
                if (!currentPlant) return;

                setSubmitState('loading');

                setTimeout(() => {
                    addLogEntry({
                        pid: currentPlant.pid,
                        action: selectedAction,
                        details: actionDetails
                    });
                    setSubmitState('success');
                    setActionDetails('');
                    setTimeout(() => setSubmitState('default'), 2000);
                }, 800);
            };

            const handleSubmitRepot = () => {
                if (!currentPlant) return;

                setSubmitState('loading');

                setTimeout(() => {
                    addLogEntry({
                        pid: currentPlant.pid,
                        action: 'REPOT',
                        details: `Pot: ${potSize}, Substrate: ${substrate}`
                    });
                    setSubmitState('success');
                    setPotSize('');
                    setSubstrate('');
                    setTimeout(() => setSubmitState('default'), 2000);
                }, 800);
            };

            const handleSubmitNote = () => {
                if (!currentPlant) return;

                setSubmitState('loading');

                setTimeout(() => {
                    addLogEntry({
                        pid: currentPlant.pid,
                        action: 'NOTE',
                        details: note
                    });
                    setSubmitState('success');
                    setNote('');
                    setTimeout(() => setSubmitState('default'), 2000);
                }, 800);
            };

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} overflow-y-auto max-w-2xl mx-auto w-full`}>
                    <PlantCard title="PLANT SCAN">
                        <div className="mb-4">
                            <PlantInput
                                label="Plant ID"
                                value={plantId}
                                onChange={setPlantId}
                                placeholder="Enter PID (e.g., P-ABC123)"
                                error={pidError}
                                required
                            />
                            <PlantButton 
                                onClick={handleScanPlant}
                                variant="primary"
                            >
                                <span className="text-xl mr-2">🔍</span>
                                Scan Plant
                            </PlantButton>
                        </div>

                        {currentPlant ? (
                            <>
                                <div className="mb-4 p-4 bg-white rounded-lg border-4 border-[#6B9C3D]">
                                    <div className="flex items-center justify-between mb-3">
                                        <span className="text-4xl">🌿</span>
                                        <div className="text-right">
                                            <p 
                                                className="text-[#4A3020]"
                                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '16px', fontWeight: '700' }}
                                            >
                                                {currentPlant.name}
                                            </p>
                                            <p 
                                                className="text-[#6B9C3D]"
                                                style={{ fontFamily: "'Press Start 2P', cursive", fontSize: '10px' }}
                                            >
                                                {currentPlant.pid}
                                            </p>
                                        </div>
                                    </div>
                                    <div 
                                        className="text-[#6B4423] flex items-center gap-2"
                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}
                                    >
                                        <span>📍</span>
                                        <span>{currentPlant.location}</span>
                                    </div>
                                </div>

                                <TabBar 
                                    tabs={tabs}
                                    activeTab={activeTab}
                                    onTabChange={setActiveTab}
                                />

                                {submitState === 'loading' && (
                                    <StatusMessage type="loading" message="Submitting..." />
                                )}

                                {submitState === 'success' && (
                                    <StatusMessage type="success" message="Action recorded successfully!" />
                                )}

                                {submitState === 'error' && (
                                    <StatusMessage 
                                        type="error" 
                                        message="Failed to record action" 
                                        onClose={() => setSubmitState('default')}
                                    />
                                )}

                                {activeTab === 'status' && (
                                    <div className="space-y-3">
                                        <div className="bg-white p-4 rounded-lg border-4 border-[#8B4513]">
                                            <p 
                                                className="text-[#4A3020] mb-2"
                                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px', fontWeight: '600' }}
                                            >
                                                Plant Health Status
                                            </p>
                                            <div className="space-y-2">
                                                <div className="flex justify-between">
                                                    <span style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}>
                                                        💧 Water Level:
                                                    </span>
                                                    <span 
                                                        className="text-[#3498DB]"
                                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px', fontWeight: '600' }}
                                                    >
                                                        Good
                                                    </span>
                                                </div>
                                                <div className="flex justify-between">
                                                    <span style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}>
                                                        ☀️ Light:
                                                    </span>
                                                    <span 
                                                        className="text-[#F39C12]"
                                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px', fontWeight: '600' }}
                                                    >
                                                        Optimal
                                                    </span>
                                                </div>
                                                <div className="flex justify-between">
                                                    <span style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px' }}>
                                                        💚 Overall:
                                                    </span>
                                                    <span 
                                                        className="text-[#6B9C3D]"
                                                        style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px', fontWeight: '600' }}
                                                    >
                                                        Healthy
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                )}

                                {activeTab === 'action' && (
                                    <div className="space-y-3">
                                        <PlantSelect
                                            label="Select Action"
                                            value={selectedAction}
                                            onChange={setSelectedAction}
                                            options={actionOptions}
                                        />
                                        <PlantInput
                                            label="Details (optional)"
                                            value={actionDetails}
                                            onChange={setActionDetails}
                                            type="textarea"
                                            placeholder="Add any notes about this action..."
                                        />
                                        <PlantButton 
                                            onClick={handleSubmitAction}
                                            variant="primary"
                                            disabled={submitState === 'loading'}
                                        >
                                            {submitState === 'loading' ? 'Submitting...' : 'Submit Action'}
                                        </PlantButton>
                                    </div>
                                )}

                                {activeTab === 'repot' && (
                                    <div className="space-y-3">
                                        <div className="bg-[#F4E4C1] p-4 rounded-lg border-4 border-[#8B4513] mb-3">
                                            <p 
                                                className="text-[#4A3020] mb-2"
                                                style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '12px', fontWeight: '600' }}
                                            >
                                                🪴 Quick Repot
                                            </p>
                                        </div>
                                        <PlantInput
                                            label="Pot Size"
                                            value={potSize}
                                            onChange={setPotSize}
                                            placeholder="e.g., 6 inch"
                                            required
                                        />
                                        <PlantInput
                                            label="Substrate"
                                            value={substrate}
                                            onChange={setSubstrate}
                                            placeholder="e.g., Cactus mix"
                                            required
                                        />
                                        <PlantButton 
                                            onClick={handleSubmitRepot}
                                            variant="primary"
                                            disabled={submitState === 'loading' || !potSize || !substrate}
                                        >
                                            {submitState === 'loading' ? 'Submitting...' : 'Submit Repot'}
                                        </PlantButton>
                                    </div>
                                )}

                                {activeTab === 'note' && (
                                    <div className="space-y-3">
                                        <PlantInput
                                            label="Note"
                                            value={note}
                                            onChange={setNote}
                                            type="textarea"
                                            placeholder="Add observations, reminders, or any notes about this plant..."
                                            required
                                        />
                                        <PlantButton 
                                            onClick={handleSubmitNote}
                                            variant="primary"
                                            disabled={submitState === 'loading' || !note}
                                        >
                                            {submitState === 'loading' ? 'Submitting...' : 'Save Note'}
                                        </PlantButton>
                                    </div>
                                )}
                            </>
                        ) : (
                            <div className="text-center py-8">
                                <div className="text-6xl mb-4">🔍</div>
                                <p 
                                    className="text-[#6B4423]"
                                    style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: '14px' }}
                                >
                                    Enter a Plant ID to begin
                                </p>
                            </div>
                        )}

                        <div className="mt-4">
                            <PlantButton onClick={goBack} variant="ghost">
                                Back to Home
                            </PlantButton>
                        </div>
                    </PlantCard>
                </div>
            );
        }

        function SpecScreen() {
            const { goBack } = useNavigation();
            const { isSmall } = useScreenSize();

            return (
                <div className={`h-full flex flex-col ${isSmall ? 'p-3' : 'p-4'} overflow-y-auto max-w-3xl mx-auto w-full`}>
                    <PlantCard title="PlantOS SPEC">
                        <div className="space-y-4 text-[#4A3020]" style={{ fontFamily: "'Pixelify Sans', cursive", fontSize: isSmall ? '11px' : '12px' }}>
                            
                            <section>
                                <h3 className="font-bold mb-2" style={{ fontSize: '14px' }}>📍 Screen Map</h3>
                                <div className="bg-white p-3 rounded border-4 border-[#8B4513]">
                                    <pre className="whitespace-pre-wrap" style={{ fontSize: '10px' }}>
{`Splash → Home
  ├─ Add Plant
  ├─ Locations
  ├─ Plant Log
  ├─ Plant Scan
  │   ├─ Status Tab
  │   ├─ Action Tab
  │   ├─ Repot Tab
  │   └─ Note Tab
  └─ Spec (this page)`}
                                    </pre>
                                </div>
                            </section>

                            <section>
                                <h3 className="font-bold mb-2" style={{ fontSize: '14px' }}>🔄 User Flow</h3>
                                <div className="bg-white p-3 rounded border-4 border-[#8B4513] space-y-2">
                                    <p><strong>1. Onboarding:</strong> Splash → Home</p>
                                    <p><strong>2. Add Plant:</strong> Home → Add Plant → [Create] → Success w/ PID → Open Scan</p>
                                    <p><strong>3. View Plants:</strong> Home → Locations → [Select Location] → Plant List</p>
                                    <p><strong>4. Log Action:</strong> Home → Scan → [Enter PID] → [Select Tab] → Submit</p>
                                    <p><strong>5. View History:</strong> Home → Plant Log → [Set Limit] → Load</p>
                                </div>
                            </section>

                            <section>
                                <h3 className="font-bold mb-2" style={{ fontSize: '14px' }}>🎨 Component Library</h3>
                                <div className="bg-white p-3 rounded border-4 border-[#8B4513] space-y-1">
                                    <p><strong>PlantButton:</strong> primary, secondary, ghost variants</p>
                                    <p><strong>PlantInput:</strong> text, textarea types with validation</p>
                                    <p><strong>PlantSelect:</strong> dropdown with custom styling</p>
                                    <p><strong>PlantCard:</strong> container with title and border</p>
                                    <p><strong>StatusMessage:</strong> success, error, info, loading states</p>
                                    <p><strong>TabBar:</strong> multi-tab navigation with icons</p>
                                </div>
                            </section>

                            <section>
                                <h3 className="font-bold mb-2" style={{ fontSize: '14px' }}>🎨 Color Palette</h3>
                                <div className="bg-white p-3 rounded border-4 border-[#8B4513] space-y-1">
                                    <div className="flex items-center gap-2">
                                        <div className="w-6 h-6 bg-[#6B9C3D] border-2 border-black"></div>
                                        <span>Primary Green: #6B9C3D</span>
                                    </div>
                                    <div className="flex items-center gap-2">
                                        <div className="w-6 h-6 bg-[#8B4513] border-2 border-black"></div>
                                        <span>Brown: #8B4513</span>
                                    </div>
                                    <div className="flex items-center gap-2">
                                        <div className="w-6 h-6 bg-[#F4E4C1] border-2 border-black"></div>
                                        <span>Cream: #F4E4C1</span>
                                    </div>
                                    <div className="flex items-center gap-2">
                                        <div className="w-6 h-6 bg-[#3498DB] border-2 border-black"></div>
                                        <span>Blue: #3498DB</span>
                                    </div>
                                    <div className="flex items-center gap-2">
                                        <div className="w-6 h-6 bg-[#E74C3C] border-2 border-black"></div>
                                        <span>Red: #E74C3C</span>
                                    </div>
                                </div>
                            </section>

                        </div>

                        <div className="mt-6">
                            <PlantButton onClick={goBack} variant="ghost">
                                Back to Home
                            </PlantButton>
                        </div>
                    </PlantCard>
                </div>
            );
        }

        // ============ MAIN APP ============
        function AppContent() {
            const { currentScreen } = useNavigation();

            const renderScreen = () => {
                switch (currentScreen) {
                    case 'splash':
                        return <SplashScreen />;
                    case 'home':
                        return <HomeScreen />;
                    case 'add-plant':
                        return <AddPlantScreen />;
                    case 'locations':
                        return <LocationsScreen />;
                    case 'plant-log':
                        return <PlantLogScreen />;
                    case 'plant-scan':
                        return <PlantScanScreen />;
                    case 'spec':
                        return <SpecScreen />;
                    default:
                        return <HomeScreen />;
                }
            };

            return (
                <div className="flex flex-col h-full relative overflow-hidden">
                    <div className="absolute inset-0 bg-[#8BC34A]">
                        <div className="absolute inset-0 opacity-20" style={{
                            backgroundImage: `repeating-linear-gradient(
                                0deg,
                                transparent,
                                transparent 2px,
                                rgba(0,0,0,0.1) 2px,
                                rgba(0,0,0,0.1) 4px
                            ),
                            repeating-linear-gradient(
                                90deg,
                                transparent,
                                transparent 2px,
                                rgba(0,0,0,0.1) 2px,
                                rgba(0,0,0,0.1) 4px
                            )`
                        }}></div>
                        
                        <div className="absolute bottom-20 left-[10%] text-4xl">🌻</div>
                        <div className="absolute bottom-32 left-[25%] text-3xl">🌷</div>
                        <div className="absolute bottom-24 right-[15%] text-4xl">🌺</div>
                        <div className="absolute bottom-40 right-[30%] text-3xl">🌼</div>
                        <div className="absolute top-20 left-[20%] text-2xl">🦋</div>
                        <div className="absolute top-32 right-[25%] text-2xl">🐝</div>
                        
                        <div className="absolute top-8 right-8 w-16 h-16 bg-[#FFD700] rounded-full border-4 border-[#FFA500] shadow-lg"></div>
                    </div>

                    <div className="flex-1 flex items-center justify-center relative z-10 overflow-auto py-8">
                        {renderScreen()}
                    </div>
                </div>
            );
        }

        function PlantOSApp() {
            return (
                <NavigationProvider>
                    <PlantDataProvider>
                        <AppContent />
                    </PlantDataProvider>
                </NavigationProvider>
            );
        }

        // ============ RENDER ============
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<PlantOSApp />);
    </script>
</body>
</html>
